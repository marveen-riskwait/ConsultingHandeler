# This file includes global variables that will be available inside your project
# 1. In the front end code you can access this variables like this: console.log(import.meta.env.VARIABLE_NAME)
# 1. In the back end code you access the variable by importing os and then typing print(os.getenv('VARIABLE_NAME'))

# Back-End Variables
DATABASE_URL=postgres://gitpod:postgres@localhost:5432/example
FLASK_APP_KEY="any key works"
FLASK_APP=src/app.py
FLASK_DEBUG=1
DEBUG=TRUE

# Auth
JWT_SECRET_KEY="change-me-in-production"

# Celery / Redis — set these to run screening & monitoring asynchronously.
# If BOTH are unset, the platform processes events INLINE (no Redis needed),
# which is handy for local development and demos.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Public data ingestion (H4)
# Screening provider: composite (default: local OFAC/UN/EU watchlists + demo
# mock), local_watchlist, or mock. Load the lists with `flask ingest-watchlists`.
#SCREENING_PROVIDER=composite
# Companies House (UK registry) — free key from developer.company-information.service.gov.uk
# Platform-wide fallback; a per-org api_key credential in Administration → Integrations wins.
#COMPANIES_HOUSE_API_KEY=
# EU consolidated sanctions list: the Commission serves it behind a tokenised
# URL — paste yours here to fetch live; otherwise a bundled sample is used.
#EU_SANCTIONS_URL=

# Compliance Copilot (AI assistant)
# Pick a provider explicitly with AI_PROVIDER=gemini|openai|claude|mock, or
# just set ONE of the keys below (auto-detected). With no key at all the
# assistant runs in a deterministic offline demo mode.
#
# FREE option for testing: Gemini — get a key at https://aistudio.google.com
#AI_PROVIDER=gemini
#GEMINI_API_KEY=
# GEMINI_MODEL is optional: leave it UNSET and the adapter auto-discovers a
# working model for your key (Google rotates names/quotas often).
#GEMINI_MODEL=
#
# OpenAI-compatible (ChatGPT API is paid; Groq/OpenRouter have free tiers,
# Ollama is local): override OPENAI_BASE_URL for non-OpenAI backends.
#OPENAI_API_KEY=
#OPENAI_MODEL=gpt-4o-mini
#OPENAI_BASE_URL=https://api.openai.com/v1
#
# Claude (Anthropic)
#ANTHROPIC_API_KEY=sk-ant-...
#ANTHROPIC_MODEL=claude-opus-4-8
#ANTHROPIC_MAX_TOKENS=3000

# Front-End Variables
VITE_BASENAME=/
#VITE_BACKEND_URL=
