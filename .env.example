# This file includes global variables that will be available inside your project
# 1. In the front end code you can access this variables like this: console.log(import.meta.env.VARIABLE_NAME)
# 1. In the back end code you access the variable by importing os and then typing print(os.getenv('VARIABLE_NAME'))

# Back-End Variables
DATABASE_URL=postgres://gitpod:postgres@localhost:5432/example
FLASK_APP_KEY="any key works"
FLASK_APP=src/app.py
FLASK_DEBUG=1
DEBUG=TRUE

# Auth
JWT_SECRET_KEY="change-me-in-production"

# Celery / Redis — set these to run screening & monitoring asynchronously.
# If BOTH are unset, the platform processes events INLINE (no Redis needed),
# which is handy for local development and demos.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Compliance Copilot (AI assistant)
# If ANTHROPIC_API_KEY is unset the assistant runs in a deterministic demo
# mode (no network, canned replies). Set it to enable Claude.
#ANTHROPIC_API_KEY=sk-ant-...
#ANTHROPIC_MODEL=claude-opus-4-8
#ANTHROPIC_MAX_TOKENS=3000

# Front-End Variables
VITE_BASENAME=/
#VITE_BACKEND_URL=
