# =============================================================================
#  COMPLIANCE OS — ENVIRONMENT CONFIGURATION
# =============================================================================
#  Copy this file to `.env` at the repository root and fill in what you need:
#
#      cp .env.example .env
#
#  Everything is optional except DATABASE_URL, FLASK_APP and JWT_SECRET_KEY.
#  The platform degrades gracefully: with no external keys at all it still
#  runs end-to-end (local file storage, offline AI demo mode, free public
#  sanctions lists), which is what makes it demo-able out of the box.
#
#  IMPORTANT: `.env` is git-ignored — never commit real keys.
#  After ANY change here, RESTART the backend: the file is read at startup.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. CORE — required
# -----------------------------------------------------------------------------

# Database. PostgreSQL in the Codespace/production; SQLite works for local runs.
#   Codespace default (already provisioned):
DATABASE_URL=postgres://gitpod:postgres@localhost:5432/example
#   Local SQLite alternative:
# DATABASE_URL=sqlite:////tmp/compliance_os.db

# Flask entry point — leave as is.
FLASK_APP=src/app.py

# 1 = auto-reload + debugger (development). Set to 0 in production.
FLASK_DEBUG=1
DEBUG=TRUE

# Signs the session/API tokens. Use a long random string; changing it logs
# everyone out. Generate one with:  python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY="change-me-to-a-long-random-string"

# Legacy Flask secret used by some 4Geeks template pieces (admin panel).
FLASK_APP_KEY="any key works"


# -----------------------------------------------------------------------------
# 2. FRONT-END (Vite) — variables must start with VITE_ to reach the browser
# -----------------------------------------------------------------------------

# Base path the SPA is served from. Keep "/" unless you deploy in a sub-folder.
VITE_BASENAME=/

# URL of the BACKEND API as seen from the browser.
#   - Local:      http://localhost:3001
#   - Codespace:  https://<your-codespace-name>-3001.app.github.dev
#   - Production: https://your-domain (same origin => may be left empty)
# If this is empty the app shows the "set your backend URL" placeholder screen.
VITE_BACKEND_URL=http://localhost:3001


# -----------------------------------------------------------------------------
# 3. ASYNC PROCESSING (optional) — Celery + Redis
# -----------------------------------------------------------------------------
# With BOTH unset, compliance events are processed INLINE (no Redis needed) —
# perfect for demos. Set them to run screening, monitoring sweeps and customer
# enrichment in background workers (required for real scale).
#   Start a worker:  pipenv run celery -A api.celery_app.celery worker -l info
#   Start the beat:  pipenv run celery -A api.celery_app.celery beat -l info
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0


# -----------------------------------------------------------------------------
# 4. AI — Compliance Copilot
# -----------------------------------------------------------------------------
# Choose a provider explicitly, or leave AI_PROVIDER unset and the platform
# picks whichever key is present (Anthropic > Gemini > OpenAI > offline mock).
# With NO key the Copilot runs in a deterministic demo mode (no network).
#   Values: gemini | openai | claude | mock
# AI_PROVIDER=gemini

# --- Google Gemini — the FREE option, recommended for testing.
#     Get a key (no credit card): https://aistudio.google.com  -> "Get API key"
# GEMINI_API_KEY=
#     Optional: leave UNSET so the platform auto-discovers a model your key can
#     actually use (Google rotates names and free quotas frequently).
# GEMINI_MODEL=

# --- OpenAI-compatible (ChatGPT API is paid; these backends have free tiers).
#     Change OPENAI_BASE_URL to point at a non-OpenAI provider:
#       OpenAI      https://api.openai.com/v1          (paid)
#       Groq        https://api.groq.com/openai/v1     (free tier)
#       OpenRouter  https://openrouter.ai/api/v1       (free models available)
#       Ollama      http://localhost:11434/v1          (local, key can be "ollama")
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Anthropic Claude (paid).
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# Max tokens per AI reply (all providers). Higher = longer answers, more cost.
# AI_MAX_TOKENS=3000


# -----------------------------------------------------------------------------
# 5. CHAT MEDIA STORAGE (optional) — Cloudinary
# -----------------------------------------------------------------------------
# Where voice notes / images / videos / documents shared in the team chat are
# stored. WITHOUT this, files are saved to the local ./uploads folder and
# served by the app — fine for demos, but lost when a container is rebuilt.
# Get the URL from your Cloudinary dashboard ("API Environment variable").
# A wrong value no longer breaks chat: uploads fall back to local storage.
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>


# -----------------------------------------------------------------------------
# 6. PUBLIC DATA SOURCES (enrichment + screening)
# -----------------------------------------------------------------------------
# Sanctions screening runs against LOCAL copies of the free public lists.
# Load/refresh them with:   pipenv run flask ingest-watchlists
#   OFAC (US) and UN are fetched live and need NO key.
#
# Which screening engine to use:
#   composite       (default) local public watchlists + demo mock provider
#   local_watchlist local public watchlists only
#   mock            demo data only
# SCREENING_PROVIDER=composite

# --- EU consolidated sanctions list.
#     The Commission serves it behind a tokenised URL; paste yours to fetch
#     live, otherwise a bundled sample of real EU entries is used.
# EU_SANCTIONS_URL=

# --- UK Companies House — FREE key, powers company lookups AND the automatic
#     enrichment (company profile, directors, PSC = real beneficial owners).
#     Register at: https://developer.company-information.service.gov.uk
#     Per-organization keys can also be stored in Administration -> Integrations
#     (that one wins over this platform-wide fallback).
# COMPANIES_HOUSE_API_KEY=

# NOTE — sources that need NO configuration at all:
#   GLEIF (global LEI registry), the French registry
#   (recherche-entreprises.api.gouv.fr) and GDELT (adverse media) are queried
#   automatically by the enrichment engine.


# -----------------------------------------------------------------------------
# 7. OPTIONAL / LEGACY
# -----------------------------------------------------------------------------
# Provider webhook signatures (Sumsub, ComplyAdvantage…) are configured per
# provider in Administration -> Integrations, NOT here — secrets stay in the
# database, write-only, never returned by the API.


# ---------------------------------------------------------------------------
# Customer notifications (optional)
# ---------------------------------------------------------------------------
# Emails to customers are deliberately content-free: they say that something is
# waiting and where to sign in, never which document or why. Email is
# unencrypted and, in an AML context, a message hinting at an assessment can
# amount to unlawful disclosure. Without SMTP configured the platform simply
# does not send — no workflow depends on it.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=notifications@example.com
# SMTP_PASSWORD=
# MAIL_FROM="Acme Compliance <notifications@example.com>"
# PORTAL_URL=https://portal.example.com
# MAIL_SUPPRESS=1        # keep it quiet in development
