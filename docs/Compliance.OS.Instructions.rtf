\f0\b0\fs26 \cf0 I would create a generic event system.\
\pard\pardeftab560\slleading20\partightenfactor0

\f2\fs24 \cf0 class ComplianceEvent(db.Model):\
    id = db.Column(db.Integer, primary_key=True)\
\
    customer_id = db.Column(\
        db.Integer,\
        db.ForeignKey("customer.id"),\
        nullable=True\
    )\
\
    event_type = db.Column(db.String(100), nullable=False)\
\
    source = db.Column(db.String(100))\
    severity = db.Column(db.String(20))\
\
    payload = db.Column(db.JSON)\
\
    status = db.Column(db.String(30), default="NEW")\
\
    detected_at = db.Column(db.DateTime)\
    processed_at = db.Column(db.DateTime)\
\pard\pardeftab560\slleading20\partightenfactor0

\f0\fs26 \cf0 Example:\
\pard\pardeftab560\slleading20\partightenfactor0

\f2\fs24 \cf0 \{\
  "event_type": "DOCUMENT_EXPIRING",\
  "customer_id": 123,\
  "severity": "MEDIUM",\
  "payload": \{\
    "document_type": "passport",\
    "expires_at": "2026-08-15",\
    "days_remaining": 30\
  \}\
\}\
\pard\pardeftab560\slleading20\partightenfactor0

\f0\fs26 \cf0 Another:\
\pard\pardeftab560\slleading20\partightenfactor0

\f2\fs24 \cf0 \{\
  "event_type": "PEP_STATUS_CHANGED",\
  "customer_id": 123,\
  "severity": "HIGH",\
  "payload": \{\
    "previous_status": false,\
    "new_status": true,\
    "source": "screening_provider"\
  \}\
\}\
\pard\pardeftab560\slleading20\partightenfactor0

